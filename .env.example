LLM_API_KEY=your-api-key
LLM_BASE_URL=https://routerai.ru/api/v1
LLM_EXPLORER_MODEL=qwen/qwen3-max-thinking
LLM_ENGINEER_MODEL=qwen/qwen3-coder-next
LLM_CRITIC_MODEL=qwen/qwen3-max-thinking
LLM_DEBUGGER_MODEL=qwen/qwen3-coder-next
LLM_FUNCTION_CALLING_ENABLED=true
LLM_STRUCTURED_OUTPUTS_ENABLED=true
LLM_REQUEST_TIMEOUT_SECONDS=180

# Optional RAG settings
# Set RAG_ENABLED=true after Qdrant is running and the embedding endpoint is configured.
RAG_ENABLED=false
RAG_CONTEXT_CSV_PATH=rag_context/kaggle_writeups_0341_03202026.csv
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=kaggle_writeups
# RAG_QDRANT_API_KEY=
RAG_QDRANT_TIMEOUT_SECONDS=30
RAG_TOP_K=5
RAG_MAX_TOP_K=5
RAG_AUTO_REINDEX=true
RAG_INDEXING_BATCH_SIZE=32

# Required when RAG_ENABLED=true
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=https://your-embedding-provider.example.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_REQUEST_TIMEOUT_SECONDS=180

# Optional runtime overrides
# KAGGLE_SOLVER_LOG_LEVEL=INFO
# KAGGLE_SOLVER_TARGET_COL=target
# KAGGLE_SOLVER_ID_COL=_id
# KAGGLE_SOLVER_MAX_ITERS=4
# KAGGLE_SOLVER_MAIN_METRIC=MSE
# KAGGLE_SOLVER_VALID_SIZE=0.2
# KAGGLE_SOLVER_RANDOM_SEED=42
# KAGGLE_SOLVER_EXECUTOR_TIMEOUT=400
# KAGGLE_SOLVER_DATA_DIR=./data
# KAGGLE_SOLVER_ARTIFACTS_DIR=./artifacts
